{
  // Med-Guide — Zed AI Configuration
  // Copy this file as .zed/settings.json to use.
  //
  // IMPORTANT: You must first configure your OpenRouter API key:
  //   1. Open Command Palette → "agent: open settings"
  //   2. Find the OpenRouter section → paste your API key
  //   Or set the OPENROUTER_API_KEY environment variable.
  //
  // Get an API key at: https://openrouter.ai/keys

  "agent": {
    "default_model": {
      "provider": "openrouter",
      "model": "anthropic/claude-sonnet-4"
    }
  }

  // Optional: Uncomment to add more models to the picker.
  //
  // "language_models": {
